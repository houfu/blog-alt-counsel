{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -d node_modules ] || npm install --no-audit --no-fund > /dev/null 2>&1 && echo 'npm dependencies ready'"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ghst-auth.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-wrap.sh"
          }
        ]
      }
    ]
  }
}
