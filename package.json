{
  "name": "blog-alt-counsel",
  "version": "1.0.0",
  "description": "A lightweight collection of Claude Code subagents that automate the entire lifecycle of a Ghost blog post",
  "scripts": {
    "setup-hooks": "ln -sf ../../.claude/hooks/pre-commit .git/hooks/pre-commit && echo 'Pre-commit hook installed successfully.'",
    "sync-ghost": "node -r dotenv/config scripts/sync-from-ghost.js"
  },
  "keywords": [
    "ghost",
    "blog",
    "api",
    "claude",
    "automation"
  ],
  "author": "Ang Hou Fu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/houfu/blog-alt-counsel.git"
  },
  "homepage": "https://github.com/houfu/blog-alt-counsel#readme",
  "bugs": {
    "url": "https://github.com/houfu/blog-alt-counsel/issues"
  },
  "dependencies": {
    "@tryghost/admin-api": "^1.14.4",
    "gray-matter": "^4.0.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "dotenv": "^17.2.4",
    "marked": "^17.0.1",
    "node-fetch": "^3.3.2"
  }
}
